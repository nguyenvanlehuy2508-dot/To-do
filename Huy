<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Nguyễn Minh Khải — Dev</title>
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:ital,wght@0,400;0,700;1,400&family=Syne:wght@400;700;800&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #080b0f;
    --bg2: #0d1117;
    --surface: #111820;
    --border: #1e2d3d;
    --accent: #00e5ff;
    --accent2: #ff3d71;
    --accent3: #a8ff3e;
    --text: #c9d5e0;
    --text-dim: #4a6070;
    --text-bright: #eef4f8;
    --mono: 'Space Mono', monospace;
    --sans: 'Syne', sans-serif;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html { scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--mono);
    font-size: 14px;
    line-height: 1.7;
    overflow-x: hidden;
    cursor: none;
  }

  /* Custom cursor */
  .cursor {
    position: fixed;
    width: 8px; height: 8px;
    background: var(--accent);
    border-radius: 50%;
    pointer-events: none;
    z-index: 9999;
    transition: transform 0.1s;
    mix-blend-mode: screen;
  }
  .cursor-ring {
    position: fixed;
    width: 32px; height: 32px;
    border: 1px solid rgba(0,229,255,0.4);
    border-radius: 50%;
    pointer-events: none;
    z-index: 9998;
    transition: transform 0.15s, width 0.2s, height 0.2s;
    transform: translate(-12px, -12px);
  }
  body:hover .cursor { opacity: 1; }

  /* Noise overlay */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 1000;
    opacity: 0.5;
  }

  /* Scanlines */
  body::after {
    content: '';
    position: fixed;
    inset: 0;
    background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,0,0,0.03) 2px, rgba(0,0,0,0.03) 4px);
    pointer-events: none;
    z-index: 999;
  }

  /* NAV */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 48px;
    background: linear-gradient(to bottom, rgba(8,11,15,0.95), transparent);
    backdrop-filter: blur(2px);
  }
  .nav-logo {
    font-family: var(--sans);
    font-weight: 800;
    font-size: 18px;
    color: var(--text-bright);
    letter-spacing: -0.5px;
  }
  .nav-logo span { color: var(--accent); }
  .nav-links { display: flex; gap: 32px; list-style: none; }
  .nav-links a {
    color: var(--text-dim);
    text-decoration: none;
    font-size: 12px;
    letter-spacing: 2px;
    text-transform: uppercase;
    transition: color 0.2s;
  }
  .nav-links a:hover { color: var(--accent); }
  .nav-status {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 11px;
    color: var(--accent3);
    letter-spacing: 1px;
  }
  .status-dot {
    width: 6px; height: 6px;
    background: var(--accent3);
    border-radius: 50%;
    animation: pulse 2s infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.4; transform: scale(0.8); }
  }

  /* HERO */
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 120px 48px 80px;
    position: relative;
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    max-width: 1200px;
    width: 100%;
    margin: 0 auto;
    align-items: center;
  }
  .hero-label {
    font-size: 11px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 24px;
    opacity: 0;
    animation: fadeUp 0.8s 0.2s forwards;
  }
  .hero-name {
    font-family: var(--sans);
    font-weight: 800;
    font-size: clamp(52px, 6vw, 88px);
    line-height: 0.95;
    color: var(--text-bright);
    letter-spacing: -3px;
    margin-bottom: 8px;
    opacity: 0;
    animation: fadeUp 0.8s 0.35s forwards;
  }
  .hero-name .highlight {
    color: transparent;
    -webkit-text-stroke: 1px var(--accent);
  }
  .hero-title {
    font-size: clamp(14px, 1.5vw, 18px);
    color: var(--text-dim);
    margin-bottom: 32px;
    opacity: 0;
    animation: fadeUp 0.8s 0.5s forwards;
  }
  .hero-title span { color: var(--accent2); }
  .hero-bio {
    font-size: 13px;
    color: var(--text);
    line-height: 1.9;
    max-width: 420px;
    margin-bottom: 48px;
    opacity: 0;
    animation: fadeUp 0.8s 0.65s forwards;
  }
  .hero-cta {
    display: flex;
    gap: 16px;
    opacity: 0;
    animation: fadeUp 0.8s 0.8s forwards;
  }
  .btn {
    padding: 12px 28px;
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 2px;
    text-transform: uppercase;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: all 0.2s;
  }
  .btn-primary {
    background: var(--accent);
    color: var(--bg);
    font-weight: 700;
  }
  .btn-primary:hover { background: #fff; transform: translateY(-2px); }
  .btn-ghost {
    background: transparent;
    color: var(--text-dim);
    border: 1px solid var(--border);
  }
  .btn-ghost:hover { border-color: var(--accent); color: var(--accent); transform: translateY(-2px); }

  /* Hero right - terminal */
  .hero-terminal {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
    opacity: 0;
    animation: fadeIn 1s 0.9s forwards;
    box-shadow: 0 40px 80px rgba(0,0,0,0.5), 0 0 0 1px rgba(0,229,255,0.05);
  }
  .terminal-bar {
    background: var(--bg2);
    padding: 12px 16px;
    display: flex;
    align-items: center;
    gap: 8px;
    border-bottom: 1px solid var(--border);
  }
  .t-dot { width: 10px; height: 10px; border-radius: 50%; }
  .t-dot.r { background: #ff5f56; }
  .t-dot.y { background: #ffbd2e; }
  .t-dot.g { background: #27c93f; }
  .terminal-title { font-size: 11px; color: var(--text-dim); margin-left: auto; margin-right: auto; letter-spacing: 1px; }
  .terminal-body { padding: 24px; line-height: 2; font-size: 13px; }
  .t-line { display: flex; gap: 8px; margin-bottom: 4px; }
  .t-prompt { color: var(--accent3); }
  .t-cmd { color: var(--text-bright); }
  .t-out { color: var(--text-dim); padding-left: 16px; }
  .t-key { color: var(--accent2); }
  .t-val { color: var(--accent); }
  .t-cursor {
    display: inline-block;
    width: 8px; height: 15px;
    background: var(--accent);
    animation: blink 1s infinite;
    vertical-align: middle;
  }
  @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0} }

  /* SECTION COMMON */
  section { padding: 100px 48px; }
  .section-inner { max-width: 1200px; margin: 0 auto; }
  .section-header {
    display: flex;
    align-items: baseline;
    gap: 20px;
    margin-bottom: 64px;
  }
  .section-num {
    font-size: 11px;
    color: var(--accent);
    letter-spacing: 2px;
  }
  .section-title {
    font-family: var(--sans);
    font-size: clamp(32px, 4vw, 52px);
    font-weight: 800;
    color: var(--text-bright);
    letter-spacing: -2px;
  }
  .section-line {
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  /* SKILLS */
  .skills-section { background: var(--bg2); }
  .skills-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .skill-card {
    background: var(--surface);
    border: 1px solid var(--border);
    padding: 28px;
    transition: border-color 0.3s, transform 0.3s;
    position: relative;
    overflow: hidden;
  }
  .skill-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: var(--accent);
    transform: scaleX(0);
    transition: transform 0.3s;
    transform-origin: left;
  }
  .skill-card:hover::before { transform: scaleX(1); }
  .skill-card:hover { border-color: rgba(0,229,255,0.2); transform: translateY(-4px); }
  .skill-card:nth-child(2)::before { background: var(--accent2); }
  .skill-card:nth-child(3)::before { background: var(--accent3); }
  .skill-icon { font-size: 28px; margin-bottom: 16px; }
  .skill-name {
    font-family: var(--sans);
    font-weight: 700;
    font-size: 16px;
    color: var(--text-bright);
    margin-bottom: 8px;
  }
  .skill-desc { font-size: 12px; color: var(--text-dim); margin-bottom: 16px; }
  .skill-tags { display: flex; flex-wrap: wrap; gap: 6px; }
  .tag {
    font-size: 10px;
    letter-spacing: 1px;
    padding: 3px 8px;
    border: 1px solid var(--border);
    color: var(--text-dim);
    text-transform: uppercase;
    transition: all 0.2s;
  }
  .skill-card:hover .tag { border-color: rgba(0,229,255,0.3); color: var(--accent); }

  /* PROJECTS */
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }
  .project-card {
    background: var(--surface);
    border: 1px solid var(--border);
    padding: 36px;
    transition: all 0.3s;
    position: relative;
    overflow: hidden;
    cursor: pointer;
  }
  .project-card::after {
    content: '→';
    position: absolute;
    top: 36px; right: 36px;
    font-size: 20px;
    color: var(--text-dim);
    transition: all 0.3s;
  }
  .project-card:hover::after {
    color: var(--accent);
    transform: translate(4px, -4px);
  }
  .project-card:hover {
    border-color: rgba(0,229,255,0.2);
    transform: translateY(-4px);
    box-shadow: 0 20px 60px rgba(0,0,0,0.4);
  }
  .project-card.featured {
    grid-column: span 2;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
  }
  .project-num {
    font-size: 11px;
    color: var(--text-dim);
    letter-spacing: 2px;
    margin-bottom: 16px;
  }
  .project-name {
    font-family: var(--sans);
    font-weight: 800;
    font-size: clamp(22px, 2.5vw, 32px);
    color: var(--text-bright);
    letter-spacing: -1px;
    margin-bottom: 12px;
    line-height: 1.1;
  }
  .project-desc {
    font-size: 12px;
    color: var(--text-dim);
    line-height: 1.8;
    margin-bottom: 24px;
  }
  .project-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 24px;
  }
  .stack-tag {
    font-size: 10px;
    letter-spacing: 1px;
    padding: 4px 10px;
    background: rgba(0,229,255,0.05);
    border: 1px solid rgba(0,229,255,0.15);
    color: var(--accent);
    text-transform: uppercase;
  }
  .project-metrics {
    display: flex;
    gap: 32px;
  }
  .metric { }
  .metric-val {
    font-family: var(--sans);
    font-weight: 800;
    font-size: 28px;
    color: var(--text-bright);
    letter-spacing: -1px;
  }
  .metric-label { font-size: 10px; color: var(--text-dim); letter-spacing: 1px; text-transform: uppercase; }

  /* Featured project visual */
  .project-visual {
    background: var(--bg);
    border: 1px solid var(--border);
    height: 220px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }
  .project-visual canvas { position: absolute; inset: 0; }
  .pv-label {
    position: relative;
    font-size: 11px;
    color: var(--text-dim);
    letter-spacing: 2px;
    text-transform: uppercase;
    z-index: 1;
  }

  /* EXPERIENCE */
  .exp-section { background: var(--bg2); }
  .timeline {
    position: relative;
    padding-left: 32px;
  }
  .timeline::before {
    content: '';
    position: absolute;
    left: 0; top: 8px; bottom: 8px;
    width: 1px;
    background: var(--border);
  }
  .timeline-item {
    position: relative;
    padding-bottom: 48px;
    padding-left: 32px;
  }
  .timeline-item::before {
    content: '';
    position: absolute;
    left: -36px; top: 8px;
    width: 8px; height: 8px;
    background: var(--bg2);
    border: 1px solid var(--accent);
    border-radius: 50%;
  }
  .timeline-item:nth-child(2)::before { border-color: var(--accent2); }
  .timeline-item:nth-child(3)::before { border-color: var(--accent3); }
  .timeline-period {
    font-size: 11px;
    color: var(--accent);
    letter-spacing: 2px;
    margin-bottom: 8px;
    text-transform: uppercase;
  }
  .timeline-item:nth-child(2) .timeline-period { color: var(--accent2); }
  .timeline-item:nth-child(3) .timeline-period { color: var(--accent3); }
  .timeline-role {
    font-family: var(--sans);
    font-weight: 700;
    font-size: 22px;
    color: var(--text-bright);
    margin-bottom: 4px;
    letter-spacing: -0.5px;
  }
  .timeline-company {
    font-size: 13px;
    color: var(--text-dim);
    margin-bottom: 16px;
  }
  .timeline-desc {
    font-size: 12px;
    color: var(--text);
    line-height: 1.8;
    max-width: 600px;
  }

  /* CONTACT */
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }
  .contact-big {
    font-family: var(--sans);
    font-weight: 800;
    font-size: clamp(40px, 5vw, 72px);
    color: var(--text-bright);
    letter-spacing: -3px;
    line-height: 1;
    margin-bottom: 24px;
  }
  .contact-big span { color: transparent; -webkit-text-stroke: 1px var(--accent2); }
  .contact-sub {
    font-size: 13px;
    color: var(--text-dim);
    line-height: 1.8;
    margin-bottom: 40px;
  }
  .contact-links { display: flex; flex-direction: column; gap: 20px; }
  .contact-link {
    display: flex;
    align-items: center;
    gap: 16px;
    text-decoration: none;
    color: var(--text-dim);
    font-size: 13px;
    transition: color 0.2s;
    padding: 16px;
    border: 1px solid var(--border);
    transition: all 0.2s;
  }
  .contact-link:hover {
    color: var(--text-bright);
    border-color: rgba(0,229,255,0.3);
    transform: translateX(8px);
  }
  .contact-link-icon { font-size: 18px; }
  .contact-link-text { flex: 1; }
  .contact-link-arrow { color: var(--text-dim); transition: transform 0.2s; }
  .contact-link:hover .contact-link-arrow { transform: translateX(4px); color: var(--accent); }

  /* FOOTER */
  footer {
    padding: 32px 48px;
    border-top: 1px solid var(--border);
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 11px;
    color: var(--text-dim);
    letter-spacing: 1px;
  }

  /* ANIMATIONS */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  .reveal {
    opacity: 0;
    transform: translateY(32px);
    transition: opacity 0.7s, transform 0.7s;
  }
  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Scrollbar */
  ::-webkit-scrollbar { width: 4px; }
  ::-webkit-scrollbar-track { background: var(--bg); }
  ::-webkit-scrollbar-thumb { background: var(--border); }
  ::-webkit-scrollbar-thumb:hover { background: var(--accent); }

  @media (max-width: 768px) {
    nav { padding: 16px 24px; }
    .nav-links { display: none; }
    section { padding: 60px 24px; }
    .hero { padding: 100px 24px 60px; }
    .hero-grid { grid-template-columns: 1fr; gap: 48px; }
    .skills-grid { grid-template-columns: 1fr; }
    .projects-grid { grid-template-columns: 1fr; }
    .project-card.featured { grid-column: span 1; grid-template-columns: 1fr; }
    .contact-grid { grid-template-columns: 1fr; gap: 40px; }
    footer { flex-direction: column; gap: 12px; text-align: center; }
  }
</style>
</head>
<body>

<div class="cursor" id="cursor"></div>
<div class="cursor-ring" id="cursorRing"></div>

<!-- NAV -->
<nav>
  <div class="nav-logo">MK<span>.</span></div>
  <ul class="nav-links">
    <li><a href="#skills">Skills</a></li>
    <li><a href="#projects">Projects</a></li>
    <li><a href="#experience">Experience</a></li>
    <li><a href="#contact">Contact</a></li>
  </ul>
  <div class="nav-status">
    <div class="status-dot"></div>
    Available for work
  </div>
</nav>

<!-- HERO -->
<section class="hero" id="home">
  <div class="hero-grid">
    <div class="hero-left">
      <div class="hero-label">// Developer & Creative Coder</div>
      <h1 class="hero-name">Minh<br><span class="highlight">Khải</span></h1>
      <div class="hero-title">Full-Stack Dev · <span>Hanoi, Vietnam</span></div>
      <p class="hero-bio">
        Tôi build những thứ chạy được — từ REST API lúc 3 giờ sáng đến UI khiến người dùng không muốn rời. 5 năm cày code, nhiều đêm thức, vô số bug đã fix.
      </p>
      <div class="hero-cta">
        <a href="#projects" class="btn btn-primary">Xem Projects</a>
        <a href="#contact" class="btn btn-ghost">Get in touch</a>
      </div>
    </div>
    <div class="hero-right">
      <div class="hero-terminal">
        <div class="terminal-bar">
          <div class="t-dot r"></div>
          <div class="t-dot y"></div>
          <div class="t-dot g"></div>
          <div class="terminal-title">~/portfolio — zsh</div>
        </div>
        <div class="terminal-body">
          <div class="t-line"><span class="t-prompt">❯</span><span class="t-cmd">whoami</span></div>
          <div class="t-out">nguyenminhkhai</div>
          <div class="t-line" style="margin-top:12px"><span class="t-prompt">❯</span><span class="t-cmd">cat profile.json</span></div>
          <div class="t-out">{</div>
          <div class="t-out">&nbsp;&nbsp;<span class="t-key">"role"</span>: <span class="t-val">"Full-Stack Developer"</span>,</div>
          <div class="t-out">&nbsp;&nbsp;<span class="t-key">"exp"</span>: <span class="t-val">"5 years"</span>,</div>
          <div class="t-out">&nbsp;&nbsp;<span class="t-key">"loc"</span>: <span class="t-val">"Hanoi 🇻🇳"</span>,</div>
          <div class="t-out">&nbsp;&nbsp;<span class="t-key">"coffee"</span>: <span class="t-val">"cà phê đen"</span>,</div>
          <div class="t-out">&nbsp;&nbsp;<span class="t-key">"status"</span>: <span class="t-val" style="color:var(--accent3)">"open_to_work"</span></div>
          <div class="t-out">}</div>
          <div class="t-line" style="margin-top:12px"><span class="t-prompt">❯</span><span class="t-cursor"></span></div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- SKILLS -->
<section class="skills-section" id="skills">
  <div class="section-inner">
    <div class="section-header reveal">
      <span class="section-num">01</span>
      <h2 class="section-title">Skills</h2>
      <div class="section-line"></div>
    </div>
    <div class="skills-grid">
      <div class="skill-card reveal">
        <div class="skill-icon">⚡</div>
        <div class="skill-name">Frontend</div>
        <div class="skill-desc">Build UI đẹp, fast, responsive. Ưu tiên performance và UX thực sự tốt.</div>
        <div class="skill-tags">
          <span class="tag">React</span>
          <span class="tag">Next.js</span>
          <span class="tag">TypeScript</span>
          <span class="tag">Tailwind</span>
          <span class="tag">Three.js</span>
          <span class="tag">Framer Motion</span>
        </div>
      </div>
      <div class="skill-card reveal" style="transition-delay:0.1s">
        <div class="skill-icon">🛠️</div>
        <div class="skill-name">Backend</div>
        <div class="skill-desc">API scalable, database tối ưu, hệ thống không chết dù traffic tăng gấp 10.</div>
        <div class="skill-tags">
          <span class="tag">Node.js</span>
          <span class="tag">FastAPI</span>
          <span class="tag">PostgreSQL</span>
          <span class="tag">Redis</span>
          <span class="tag">Docker</span>
          <span class="tag">AWS</span>
        </div>
      </div>
      <div class="skill-card reveal" style="transition-delay:0.2s">
